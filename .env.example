# Copy to .env for local dev, and set the same as Variables in Railway.
# Apple Pay only works with LIVE keys — test mode does NOT show Apple Pay.
RZP_KEY_ID=rzp_live_xxxxxxxxxxxxxx
RZP_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Apple Pay is hidden for INR — keep this non-INR.
CURRENCY=USD
# Smallest currency unit. 200 = $2.00
AMOUNT=200

# Local port (Railway sets PORT automatically; don't hard-code in prod).
PORT=3000
